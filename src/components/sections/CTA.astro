---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import GradiantText from "../shared/GradiantText.astro";
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section id="contact" class=`pb-20 ${className}`>
  <Container>
    <div
      class="w-full relative py-8 md:py-10 px-6 md:px-8 rounded-2xl bg-gradient-to-br from-[#edf4f5] to-[#d8eaec] dark:from-[#0e2f3a] dark:to-[#0a1f28]"
    >
      <div class="mx-auto text-center max-w-xl md:max-w-2xl relative">
        <h1
          class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight
          font-bold text-heading-1"
        >
          Have a project in mind?
          <GradiantText> Let's talk. </GradiantText>
        </h1>
        <Paragraph className="pt-10 font-semibold">
          Reach out and tell us what you want to build. We can support full
          app delivery or collaborate with your existing team.
        </Paragraph>
        <div class="mx-auto max-w-md sm:max-w-xl pt-10">
          <BtnLink
            href="mailto:agcodinglp@gmail.com"
            text="agcodinglp@gmail.com"
            variant="primary"
            className="w-full justify-center"
          />
        </div>
      </div>
    </div>
  </Container>
</section>
